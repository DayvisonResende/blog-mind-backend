# Servidor
PORT=3333
NODE_ENV=development

# CORS - origem do frontend
CORS_ORIGIN=http://localhost:5173

# Banco de dados MySQL (usado pela DATABASE_URL do Prisma)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha
DB_NAME=blog_mind

# String de conexao do Prisma
DATABASE_URL="mysql://root:sua_senha@localhost:3306/blog_mind"

# Autenticacao JWT
JWT_SECRET=troque_por_um_segredo_forte_e_aleatorio
JWT_EXPIRES=1d
